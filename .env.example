# Financial Analysis Application - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# FINANCIAL DATA API KEYS
# At least one is recommended for real-time price data; app works without them
# using Excel files as primary data source.
# =============================================================================

# Alpha Vantage - https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Financial Modeling Prep - https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# Polygon.io - https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_polygon_api_key_here

# Twelve Data - https://twelvedata.com/account/api-keys
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================

# Environment: development | testing | production (default: development)
FINANCIAL_ANALYSIS_ENV=development

# Log level override: DEBUG | INFO | WARNING | ERROR (default: INFO)
# FINANCIAL_ANALYSIS_LOG_LEVEL=INFO

# Custom cache directory (default: data_cache)
# FINANCIAL_ANALYSIS_CACHE_DIR=data_cache

# =============================================================================
# TASK MASTER AI - Development Tooling
# Required only if using Task Master AI workflow management (not used by the financial analysis app)
# =============================================================================

# Claude models (Recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Research features (Highly recommended for --research flag)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
